# ============================================================
# RICMS Environment Variables
# Copy this file to .env and fill in production values.
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=ricms_secret

# JWT signing secret (must be at least 256 bits / 32+ characters)
JWT_SECRET=a-very-long-secret-key-for-ricms-that-is-at-least-256-bits-long-and-secure

# AES-256-GCM key for encrypting sensitive fields at rest.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
